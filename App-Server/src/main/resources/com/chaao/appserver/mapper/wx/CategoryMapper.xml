<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.chaao.appserver.mapper.wx.CategoryMapper">

    <select id="selectAllCategory" resultType="vo.wx.CategoryVO">
        SELECT id, name, type, status
        FROM category
        WHERE deleted = 0
        AND status = 1
        ORDER BY sort ASC, create_time ASC
    </select>

</mapper>