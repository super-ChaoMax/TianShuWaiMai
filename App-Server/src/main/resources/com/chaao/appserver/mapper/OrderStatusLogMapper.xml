<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chaao.appserver.mapper.OrderStatusLogMapper">

    <!-- 通用结果映射 -->
    <resultMap id="BaseResultMap" type="entity.OrderStatusLog">
        <id column="id" property="id"/>
        <result column="order_id" property="orderId"/>
        <result column="from_status" property="fromStatus"/>
        <result column="to_status" property="toStatus"/>
        <result column="operator_type" property="operatorType"/>
        <result column="operator_id" property="operatorId"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 新增状态日志 -->
    <insert id="insert">
        INSERT INTO order_status_log
        (id,order_id,from_status,to_status,operator_type,operator_id,remark,create_time)
        VALUES
        (#{id},#{orderId},#{fromStatus},#{toStatus},#{operatorType},#{operatorId},#{remark},NOW())
    </insert>

    <!-- 根据订单ID查询流转日志 -->
    <select id="getListByOrderId" resultMap="BaseResultMap">
        SELECT * FROM order_status_log
        WHERE order_id = #{orderId}
        ORDER BY create_time ASC
    </select>

    <!-- 查询订单最新上一个状态 -->
    <select id="getLastOrderStatus" resultType="java.lang.Integer">
        SELECT to_status FROM order_status_log
        WHERE order_id = #{orderId}
        ORDER BY create_time DESC
        LIMIT 1
    </select>

</mapper>